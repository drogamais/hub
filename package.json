{
  "name": "hub-drogamais",
  "version": "1.0.0",
  "description": "Hub Central Drogamais – Fastify SSR",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "build:css": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/style.css --watch"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/view": "^10.0.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3", 
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
    "@fastify/static": "^8.1.0",
    "@fastify/view": "^10.0.2",
    "@prisma/client": "^4.15.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prisma": "^4.15.0",
    "tailwindcss": "^4.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }

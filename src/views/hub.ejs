<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hub Drogamais – Meus Aplicativos</title>
  <meta name="description" content="Hub Central Drogamais – Acesse seus aplicativos." />
  <link rel="stylesheet" href="/public/css/style.css">
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top,_#f8fafc,_#e2e8f0_100%)] font-sans">

  <div class="flex h-screen overflow-hidden">

    <aside class="hidden w-64 flex-shrink-0 flex-col bg-white shadow-panel lg:flex">
      <div class="flex h-16 items-center gap-3 px-6 border-b border-slate-100">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-sid-600 text-sm font-bold text-white">H</div>
        <span class="text-lg font-bold text-ink">Hub Drogamais</span>
      </div>

      <nav class="flex-1 space-y-1 px-3 py-4">
        
        <a href="/app/hub" class="flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition">
          <span>📊</span> Meu Hub
        </a>

        <% if (user && user.role === 'admin' && ['TI', 'INTELIGÊNCIA DE MERCADO'].includes(user.setor)) { %>
          <a href="/app/apps" class="flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition">
            <span>⚙️</span> Gerenciar Intranets
          </a>
        <% } %>

        <% if (user && user.role === 'admin' && ['TI', 'INTELIGÊNCIA DE MERCADO'].includes(user.setor)) { %>
          <a href="/app/users" class="flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition">
            <span>👥</span> Usuários
          </a>
        <% } %>

      </nav>

      <div class="border-t border-slate-100 px-4 py-4">
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-100 text-sm font-bold text-slate-600">
            <%= (user.first_name[0] || '') + (user.last_name[0] || '') %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="truncate text-sm font-semibold text-ink"><%= user.first_name %> <%= user.last_name %></p>
            <p class="truncate text-xs text-slate-400"><%= user.email %></p>
          </div>
        </div>
        <button onclick="showLogoutModal()" class="mt-3 w-full rounded-xl border border-slate-200 px-3 py-2 text-xs font-medium text-slate-500 transition hover:bg-red-50 hover:text-red-600 hover:border-red-200">
          Sair
        </button>
      </div>
    </aside>

    <main class="flex-1 overflow-y-auto">
      <div class="mx-auto max-w-7xl p-8">
        
        <div class="mb-6 flex items-center justify-between lg:hidden">
          <div class="flex items-center gap-2">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-sid-600 text-sm font-bold text-white">H</div>
            <span class="text-lg font-bold text-ink">Hub</span>
          </div>
          <button onclick="showLogoutModal()" class="rounded-xl border border-slate-200 px-3 py-1.5 text-xs font-medium text-slate-500">Sair</button>
        </div>

        <section class="mb-8">
          <h2 class="text-3xl font-bold text-ink">Meus Aplicativos</h2>
          <p class="mt-2 text-slate-500">Selecione abaixo a Intranet que deseja acessar.</p>
        </section>

        <section id="appsGrid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% if (apps && apps.length > 0) { %>
            <% apps.forEach(app => { %>
              <a href="<%= app.url %>" 
                 onclick="appendSSOTokens(event, this)"
                 class="group block rounded-3xl bg-white p-6 shadow-panel transition hover:-translate-y-1 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-sid-500">
                <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-50 text-2xl text-sid-600 group-hover:bg-sid-50 group-hover:text-sid-700 transition">
                  <span class="uppercase font-bold"><%= app.nome.charAt(0) %></span>
                </div>
                <h3 class="text-xl font-bold text-ink"><%= app.nome %></h3>
                <p class="mt-2 text-sm text-slate-500"><%= app.url %></p>
              </a>
            <% }) %>
          <% } else { %>
            <div class="col-span-full rounded-3xl bg-white p-6 shadow-panel">
              <p class="text-slate-600">Você não possui permissão para acessar nenhuma aplicação. Contate o administrador.</p>
            </div>
          <% } %>
        </section>
      </div>
    </main>
  </div>

  <%- include('partials/modal-logout') %>

  <script src="/public/js/auth-shared.js"></script>
  <script src="/public/js/hub.js"></script>
</body>
</html>
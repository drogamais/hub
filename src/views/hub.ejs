<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hub Drogamais – Meus Aplicativos</title>
  <meta name="description" content="Hub Central Drogamais – Acesse seus aplicativos." />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sid: {
              50:  '#fef2f2',
              100: '#fee2e2',
              200: '#fecaca',
              500: '#c42c2c',
              600: '#b91c1c',
              700: '#991b1b',
            },
            ink: '#1e293b',
          },
          boxShadow: {
            panel: '0 8px 30px rgba(0,0,0,.06)',
          },
        },
      },
    };
  </script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap');
  </style>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top,_#f8fafc,_#e2e8f0_100%)]">

  <!-- Sidebar + Main -->
  <div class="flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="hidden w-64 flex-shrink-0 flex-col bg-white shadow-panel lg:flex">
      <div class="flex h-16 items-center gap-3 px-6 border-b border-slate-100">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-sid-600 text-sm font-bold text-white">H</div>
        <span class="text-lg font-bold text-ink">Hub Drogamais</span>
      </div>

      <nav id="sidebarNav" class="flex-1 space-y-1 px-3 py-4">
        <a href="/app/hub" class="flex items-center gap-3 rounded-xl bg-sid-50 px-4 py-2.5 text-sm font-semibold text-sid-700">
          <span>📊</span> Aplicativos
        </a>
      </nav>

      <div class="border-t border-slate-100 px-4 py-4">
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-100 text-sm font-bold text-slate-600" id="avatarInitial">?</div>
          <div class="flex-1 min-w-0">
            <p class="truncate text-sm font-semibold text-ink" id="sidebarUserName">Usuário</p>
            <p class="truncate text-xs text-slate-400" id="sidebarUserEmail">email</p>
          </div>
        </div>
        <button id="logoutBtn" class="mt-3 w-full rounded-xl border border-slate-200 px-3 py-2 text-xs font-medium text-slate-500 transition hover:bg-red-50 hover:text-red-600 hover:border-red-200">
          Sair
        </button>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <div class="mx-auto max-w-7xl p-8">

        <!-- Mobile header -->
        <div class="mb-6 flex items-center justify-between lg:hidden">
          <div class="flex items-center gap-2">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-sid-600 text-sm font-bold text-white">H</div>
            <span class="text-lg font-bold text-ink">Hub</span>
          </div>
          <button id="logoutBtnMobile" class="rounded-xl border border-slate-200 px-3 py-1.5 text-xs font-medium text-slate-500 hover:bg-red-50 hover:text-red-600">Sair</button>
        </div>

        <section class="mb-8">
          <h2 class="text-3xl font-bold text-ink">Meus Aplicativos</h2>
          <p class="mt-2 text-slate-500">
            Você está no Hub Central da Drogamais. Selecione abaixo a Intranet que deseja acessar.
          </p>
        </section>

        <div id="noAppsMsg" class="hidden rounded-3xl bg-white p-6 shadow-panel">
          <p class="text-slate-600">Você não possui permissão para acessar nenhuma aplicação no momento. Contate o administrador.</p>
        </div>

        <section id="appsGrid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3"></section>
      </div>
    </main>
  </div>

  <script>
    // ─── Storage keys ────────────────────────────────────────────────
    const ACCESS_KEY  = 'sid_access_token';
    const REFRESH_KEY = 'sid_refresh_token';
    const USER_KEY    = 'sid_user';

    function getStoredUser() {
      try { return JSON.parse(localStorage.getItem(USER_KEY)); } catch { return null; }
    }

    function clearSession() {
      localStorage.removeItem(ACCESS_KEY);
      localStorage.removeItem(REFRESH_KEY);
      localStorage.removeItem(USER_KEY);
      // Limpa o cookie SSO (não-HttpOnly fallback) pela rota do servidor
      fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin' }).catch(() => {});
    }

    // ─── Guard: se não está logado, vai pro login ────────────────────
    const user = getStoredUser();
    if (!user) {
      window.location.href = '/login';
    }

    // ─── Popula sidebar ──────────────────────────────────────────────
    if (user) {
      const initials = ((user.first_name || '')[0] || '') + ((user.last_name || '')[0] || '');
      document.getElementById('avatarInitial').textContent = initials.toUpperCase() || '?';
      document.getElementById('sidebarUserName').textContent = (user.first_name + ' ' + user.last_name).trim() || user.username;
      document.getElementById('sidebarUserEmail').textContent = user.email || user.username;

      // Mostra link de Usuários para superAdmin
      const superSectors = ['TI', 'INTELIGÊNCIA DE MERCADO'];
      if (user.role === 'admin' && superSectors.includes(user.setor || '')) {
        const nav = document.getElementById('sidebarNav');
        const usersLink = document.createElement('a');
        usersLink.href = '/app/users';
        usersLink.className = 'flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition';
        usersLink.innerHTML = '<span>👥</span> Usuários';
        nav.appendChild(usersLink);
      }
    }

    // ─── Renderiza apps ──────────────────────────────────────────────
    const apps     = (user && user.aplicacoes) || [];
    const grid     = document.getElementById('appsGrid');
    const noApps   = document.getElementById('noAppsMsg');
    const token    = localStorage.getItem(ACCESS_KEY) || '';
    const refresh  = localStorage.getItem(REFRESH_KEY) || '';
    const userData = encodeURIComponent(JSON.stringify(user));

    if (apps.length === 0) {
      noApps.classList.remove('hidden');
    } else {
      apps.forEach(app => {
        const link = document.createElement('a');
        const separator = app.url.includes('?') ? '&' : '?';
        link.href = app.url + separator + 'access_token=' + token + '&refresh_token=' + refresh + '&user=' + userData;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.className = 'group block rounded-3xl bg-white p-6 shadow-panel transition hover:-translate-y-1 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-sid-500';
        link.innerHTML = `
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-50 text-2xl text-sid-600 group-hover:bg-sid-50 group-hover:text-sid-700 transition">
            <span class="uppercase font-bold">${app.nome.charAt(0)}</span>
          </div>
          <h3 class="text-xl font-bold text-ink">${app.nome}</h3>
          <p class="mt-2 text-sm text-slate-500">${app.url}</p>
        `;
        grid.appendChild(link);
      });
    }

    // ─── Logout ──────────────────────────────────────────────────────
    function handleLogout() {
      clearSession();
      window.location.href = '/login';
    }

    document.getElementById('logoutBtn').addEventListener('click', handleLogout);
    document.getElementById('logoutBtnMobile').addEventListener('click', handleLogout);
  </script>
</body>
</html>

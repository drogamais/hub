<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hub Drogamais – Usuários</title>
  <meta name="description" content="Gerenciamento de usuários do Hub Drogamais." />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sid: { 50:'#fef2f2', 100:'#fee2e2', 200:'#fecaca', 500:'#c42c2c', 600:'#b91c1c', 700:'#991b1b' },
            ink: '#1e293b',
          },
          boxShadow: { panel: '0 8px 30px rgba(0,0,0,.06)' },
        },
      },
    };
  </script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap');
  </style>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top,_#f8fafc,_#e2e8f0_100%)]">
  <div class="flex h-screen overflow-hidden">

    <!-- ── Sidebar ──────────────────────────────────────────── -->
    <aside class="hidden w-64 flex-shrink-0 flex-col bg-white shadow-panel lg:flex">
      <div class="flex h-16 items-center gap-3 px-6 border-b border-slate-100">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-sid-600 text-sm font-bold text-white">H</div>
        <span class="text-lg font-bold text-ink">Hub Drogamais</span>
      </div>
      <nav class="flex-1 space-y-1 px-3 py-4">
        <a href="/app/hub" class="flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition">
          <span>📊</span> Aplicativos
        </a>
        <a href="/app/users" class="flex items-center gap-3 rounded-xl bg-sid-50 px-4 py-2.5 text-sm font-semibold text-sid-700">
          <span>👥</span> Usuários
        </a>
      </nav>
      <div class="border-t border-slate-100 px-4 py-4">
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-100 text-sm font-bold text-slate-600" id="avatarInitial">?</div>
          <div class="flex-1 min-w-0">
            <p class="truncate text-sm font-semibold text-ink" id="sidebarUserName">Usuário</p>
            <p class="truncate text-xs text-slate-400" id="sidebarUserEmail">email</p>
          </div>
        </div>
        <button id="logoutBtn" class="mt-3 w-full rounded-xl border border-slate-200 px-3 py-2 text-xs font-medium text-slate-500 transition hover:bg-red-50 hover:text-red-600 hover:border-red-200">Sair</button>
      </div>
    </aside>

    <!-- ── Main ──────────────────────────────────────────────── -->
    <main class="flex-1 overflow-y-auto">
      <div class="mx-auto max-w-7xl p-8 space-y-6">

        <!-- Mobile header -->
        <div class="mb-2 flex items-center justify-between lg:hidden">
          <div class="flex items-center gap-2">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-sid-600 text-sm font-bold text-white">H</div>
            <span class="text-lg font-bold text-ink">Hub</span>
          </div>
          <button id="logoutBtnMobile" class="rounded-xl border border-slate-200 px-3 py-1.5 text-xs font-medium text-slate-500 hover:bg-red-50 hover:text-red-600">Sair</button>
        </div>

        <!-- Header card -->
        <section class="rounded-3xl bg-white p-6 shadow-panel">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Administração</p>
              <h2 class="text-3xl font-bold text-ink">Usuários</h2>
              <p class="mt-2 text-sm text-slate-500">Cadastro e manutenção de acessos restritos ao perfil admin.</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="rounded-2xl bg-slate-100 px-4 py-3 text-sm text-slate-600">
                Total: <span class="font-semibold text-ink" id="totalCount">--</span>
              </div>
              <button id="newUserBtn" class="rounded-2xl bg-sid-600 px-4 py-3 text-sm font-semibold text-white hover:bg-sid-700" type="button">Novo usuário</button>
            </div>
          </div>
        </section>

        <!-- Search / Sort -->
        <section class="rounded-3xl bg-white p-6 shadow-panel">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <form id="searchForm" class="flex flex-1 gap-3">
              <input id="searchInput" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-sid-500 focus:bg-white" placeholder="Buscar por nome ou e-mail" />
              <button class="rounded-2xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white" type="submit">Buscar</button>
            </form>
            <div class="flex flex-wrap gap-2">
              <button class="sort-btn rounded-2xl border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600" data-field="first_name" type="button">Ordenar por nome</button>
              <button class="sort-btn rounded-2xl border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600" data-field="email" type="button">Ordenar por e-mail</button>
              <button class="sort-btn rounded-2xl border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600" data-field="role" type="button">Ordenar por perfil</button>
            </div>
          </div>
        </section>

        <!-- Error -->
        <p id="listError" class="hidden rounded-3xl bg-red-50 px-5 py-4 text-sm text-red-700"></p>

        <!-- Table -->
        <section class="overflow-hidden rounded-3xl bg-white shadow-panel">
          <div class="overflow-x-auto">
            <table class="min-w-full border-collapse">
              <thead class="bg-slate-50 text-left text-xs uppercase tracking-[0.18em] text-slate-500">
                <tr>
                  <th class="px-5 py-4">Nome</th>
                  <th class="px-5 py-4">E-mail</th>
                  <th class="px-5 py-4">Username</th>
                  <th class="px-5 py-4">Perfil</th>
                  <th class="px-5 py-4">Setor</th>
                  <th class="px-5 py-4">Status</th>
                  <th class="px-5 py-4">Ações</th>
                </tr>
              </thead>
              <tbody id="usersTableBody">
                <tr><td class="px-5 py-10 text-center text-sm text-slate-500" colspan="7">Carregando usuários...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="flex flex-col gap-3 border-t border-slate-100 px-5 py-4 text-sm text-slate-500 md:flex-row md:items-center md:justify-between">
            <p id="pageInfo">Página 1 de 1</p>
            <div class="flex gap-3">
              <button id="prevBtn" class="rounded-2xl border border-slate-200 px-4 py-2 font-semibold text-slate-600 disabled:cursor-not-allowed disabled:opacity-50" disabled type="button">Anterior</button>
              <button id="nextBtn" class="rounded-2xl border border-slate-200 px-4 py-2 font-semibold text-slate-600 disabled:cursor-not-allowed disabled:opacity-50" disabled type="button">Próxima</button>
            </div>
          </div>
        </section>

      </div>
    </main>
  </div>

  <!-- ── Modal ────────────────────────────────────────────────── -->
  <div id="formModal" class="fixed inset-0 z-50 hidden items-start justify-center bg-slate-950/30 px-4 py-8" style="display:none;">
    <div class="max-h-full w-full max-w-3xl overflow-y-auto rounded-3xl bg-white p-6 shadow-2xl">
      <div class="mb-6 flex items-start justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Administração</p>
          <h3 id="modalTitle" class="text-2xl font-bold text-ink">Novo usuário</h3>
        </div>
        <button id="modalCloseBtn" class="rounded-2xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600" type="button">Fechar</button>
      </div>

      <form id="userForm" class="space-y-6">
        <input type="hidden" id="editingId" value="" />
        <div class="grid gap-4 md:grid-cols-2">
          <label class="text-sm text-slate-600 md:col-span-2">
            <span class="mb-2 block font-medium">E-mail</span>
            <input id="f_email" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-sid-500 focus:bg-white" name="email" required type="email" />
          </label>
          <label class="text-sm text-slate-600">
            <span class="mb-2 block font-medium">Primeiro nome</span>
            <input id="f_first_name" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-sid-500 focus:bg-white" name="first_name" />
          </label>
          <label class="text-sm text-slate-600">
            <span class="mb-2 block font-medium">Sobrenome</span>
            <input id="f_last_name" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-sid-500 focus:bg-white" name="last_name" />
          </label>
          <label class="text-sm text-slate-600">
            <span class="mb-2 block font-medium">Perfil</span>
            <select id="f_role" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-sid-500 focus:bg-white" name="role">
              <option value="general">General</option>
              <option value="admin">Admin</option>
            </select>
          </label>
          <label class="text-sm text-slate-600">
            <span class="mb-2 block font-medium">Setor</span>
            <select id="f_setor" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-sid-500 focus:bg-white" name="setor">
              <option value="">Selecione um setor...</option>
              <option value="ADMINISTRATIVO">Administrativo</option>
              <option value="APOIO AO ASSOCIADO">Apoio ao Associado</option>
              <option value="COMERCIAL - APF">Comercial - APF</option>
              <option value="COMERCIAL - CD">Comercial - CD</option>
              <option value="CONVENIO">Convenio</option>
              <option value="FINANCEIRO - APF">Financeiro - APF</option>
              <option value="FINANCEIRO - CD">Financeiro - CD</option>
              <option value="INTELIGÊNCIA DE MERCADO">Inteligência de Mercado</option>
              <option value="MARKETING">Marketing</option>
              <option value="TH">TH</option>
              <option value="TI">TI</option>
            </select>
          </label>
          <label class="text-sm text-slate-600">
            <span class="mb-2 block font-medium" id="passwordLabel">Senha</span>
            <input id="f_password" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none transition focus:border-sid-500 focus:bg-white" name="password" type="password" />
          </label>
        </div>

        <label class="flex items-center gap-3 rounded-2xl bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700">
          <input id="f_is_active" type="checkbox" checked /> Usuário ativo
        </label>

        <!-- Apps checkboxes -->
        <div id="appsSection" class="hidden">
          <p class="mb-3 text-sm font-medium text-slate-600">Acesso a Intranets</p>
          <div id="appsGrid" class="grid gap-3 sm:grid-cols-2"></div>
        </div>

        <p id="formError" class="hidden rounded-2xl bg-red-50 px-4 py-3 text-sm text-red-700"></p>

        <div class="flex justify-end gap-3">
          <button id="modalCancelBtn" class="rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-600" type="button">Cancelar</button>
          <button id="modalSubmitBtn" class="rounded-2xl bg-sid-600 px-4 py-3 text-sm font-semibold text-white hover:bg-sid-700 disabled:cursor-not-allowed disabled:opacity-70" type="submit">Criar usuário</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // ─── Auth helpers ────────────────────────────────────────────
    const ACCESS_KEY  = 'sid_access_token';
    const REFRESH_KEY = 'sid_refresh_token';
    const USER_KEY    = 'sid_user';

    function getToken()      { return localStorage.getItem(ACCESS_KEY); }
    function getRefresh()    { return localStorage.getItem(REFRESH_KEY); }
    function getStoredUser() { try { return JSON.parse(localStorage.getItem(USER_KEY)); } catch { return null; } }
    function isSuperAdmin(u) {
      if (!u) return false;
      return u.role === 'admin' && ['TI', 'INTELIGÊNCIA DE MERCADO'].includes(u.setor || '');
    }
    function clearSession() {
      localStorage.removeItem(ACCESS_KEY); localStorage.removeItem(REFRESH_KEY); localStorage.removeItem(USER_KEY);
      fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin' }).catch(() => {});
    }

    // ─── Guard ───────────────────────────────────────────────────
    const currentUser = getStoredUser();
    if (!currentUser) { window.location.href = '/login'; }
    if (!isSuperAdmin(currentUser)) { window.location.href = '/app/hub'; }

    // Sidebar user info
    if (currentUser) {
      const initials = ((currentUser.first_name||'')[0]||'') + ((currentUser.last_name||'')[0]||'');
      document.getElementById('avatarInitial').textContent = initials.toUpperCase() || '?';
      document.getElementById('sidebarUserName').textContent = (currentUser.first_name + ' ' + currentUser.last_name).trim() || currentUser.username;
      document.getElementById('sidebarUserEmail').textContent = currentUser.email || currentUser.username;
    }

    // ─── API helper ──────────────────────────────────────────────
    async function api(path, opts = {}) {
      const token = getToken();
      const headers = { ...(opts.headers || {}) };
      if (token) headers['Authorization'] = 'Bearer ' + token;
      if (opts.body && !(opts.body instanceof FormData)) headers['Content-Type'] = 'application/json';
      const res = await fetch('/api' + path, { ...opts, headers });
      if (res.status === 401) {
        // Try refresh
        const refreshRes = await fetch('/api/auth/token/refresh/', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ refresh: getRefresh() }),
        });
        if (refreshRes.ok) {
          const d = await refreshRes.json();
          localStorage.setItem(ACCESS_KEY, d.access);
          headers['Authorization'] = 'Bearer ' + d.access;
          const retry = await fetch('/api' + path, { ...opts, headers });
          if (!retry.ok) { const b = await retry.json().catch(() => null); throw new Error(b?.detail || b?.message || 'Falha na requisição'); }
          return retry.status === 204 ? null : retry.json();
        }
        clearSession(); window.location.href = '/login'; return;
      }
      if (!res.ok) { const b = await res.json().catch(() => null); throw new Error(b?.detail || b?.message || 'Falha na requisição'); }
      return res.status === 204 ? null : res.json();
    }

    // ─── State ───────────────────────────────────────────────────
    let page = 1, search = '', ordering = 'first_name';
    let allApps = [];
    const PROTECTED_EMAILS = ['ti@drogamais.com.br', 'inteligencia@drogamais.com.br'];

    // ─── DOM refs ────────────────────────────────────────────────
    const tbody        = document.getElementById('usersTableBody');
    const totalEl      = document.getElementById('totalCount');
    const pageInfoEl   = document.getElementById('pageInfo');
    const prevBtnEl    = document.getElementById('prevBtn');
    const nextBtnEl    = document.getElementById('nextBtn');
    const listErrorEl  = document.getElementById('listError');
    const modal        = document.getElementById('formModal');
    const modalTitle   = document.getElementById('modalTitle');
    const submitBtn    = document.getElementById('modalSubmitBtn');
    const formErrorEl  = document.getElementById('formError');
    const passwordLbl  = document.getElementById('passwordLabel');
    const appsSection  = document.getElementById('appsSection');
    const appsGridEl   = document.getElementById('appsGrid');

    // ─── Fetch users ────────────────────────────────────────────
    async function loadUsers() {
      try {
        const params = new URLSearchParams({ page: String(page) });
        if (search) params.set('search', search);
        if (ordering) params.set('ordering', ordering);
        const data = await api('/users/?' + params.toString());
        renderTable(data);
        listErrorEl.classList.add('hidden');
      } catch (err) {
        listErrorEl.textContent = err.message; listErrorEl.classList.remove('hidden');
      }
    }

    function statusPill(active) {
      return active
        ? '<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold bg-emerald-100 text-emerald-700">Ativo</span>'
        : '<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold bg-rose-100 text-rose-700">Inativo</span>';
    }

    function renderTable(data) {
      totalEl.textContent = data.count;
      const totalPages = Math.max(1, Math.ceil(data.count / 20));
      pageInfoEl.textContent = 'Página ' + page + ' de ' + totalPages;
      prevBtnEl.disabled = page <= 1;
      nextBtnEl.disabled = !data.next;

      if (!data.results.length) {
        tbody.innerHTML = '<tr><td class="px-5 py-10 text-center text-sm text-slate-500" colspan="7">Nenhum usuário encontrado.</td></tr>';
        return;
      }

      tbody.innerHTML = data.results.map(u => {
        const name = (u.first_name + ' ' + u.last_name).trim() || 'Não informado';
        const isProtected = PROTECTED_EMAILS.includes(u.email);
        const actions = isProtected
          ? '<span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 px-3 py-2 italic bg-slate-50 rounded-xl border border-slate-100">Perfil Coringa Protegido</span>'
          : `<button class="edit-btn rounded-xl border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50 transition" data-id="${u.id}" type="button">Editar</button>
             <button class="del-btn rounded-xl border border-red-200 px-3 py-2 text-xs font-semibold text-red-700 hover:bg-red-50 transition" data-id="${u.id}" data-email="${u.email}" type="button">Excluir</button>`;

        return `<tr class="border-t border-slate-100 text-sm text-slate-700">
          <td class="px-5 py-4 font-semibold text-ink">${name}</td>
          <td class="px-5 py-4">${u.email}</td>
          <td class="px-5 py-4">${u.username}</td>
          <td class="px-5 py-4 capitalize">${u.role}</td>
          <td class="px-5 py-4 text-xs font-semibold text-slate-500">${u.setor || '--'}</td>
          <td class="px-5 py-4">${statusPill(u.is_active)}</td>
          <td class="px-5 py-4"><div class="flex gap-2">${actions}</div></td>
        </tr>`;
      }).join('');

      // Bind edit/delete buttons
      tbody.querySelectorAll('.edit-btn').forEach(btn => btn.addEventListener('click', () => openEditModal(Number(btn.dataset.id))));
      tbody.querySelectorAll('.del-btn').forEach(btn => btn.addEventListener('click', () => handleDelete(Number(btn.dataset.id), btn.dataset.email)));
    }

    // ─── Search, Sort, Pagination ────────────────────────────────
    document.getElementById('searchForm').addEventListener('submit', e => { e.preventDefault(); page = 1; search = document.getElementById('searchInput').value.trim(); loadUsers(); });
    document.querySelectorAll('.sort-btn').forEach(btn => btn.addEventListener('click', () => { const f = btn.dataset.field; page = 1; ordering = ordering === f ? '-' + f : f; loadUsers(); }));
    prevBtnEl.addEventListener('click', () => { page--; loadUsers(); });
    nextBtnEl.addEventListener('click', () => { page++; loadUsers(); });

    // ─── Modal helpers ───────────────────────────────────────────
    function openModal() { modal.style.display = 'flex'; }
    function closeModal() { modal.style.display = 'none'; formErrorEl.classList.add('hidden'); document.getElementById('editingId').value = ''; }

    document.getElementById('newUserBtn').addEventListener('click', () => {
      document.getElementById('editingId').value = '';
      modalTitle.textContent = 'Novo usuário';
      submitBtn.textContent = 'Criar usuário';
      passwordLbl.textContent = 'Senha';
      document.getElementById('f_password').required = true;
      document.getElementById('f_email').value = '';
      document.getElementById('f_first_name').value = '';
      document.getElementById('f_last_name').value = '';
      document.getElementById('f_role').value = 'general';
      document.getElementById('f_setor').value = '';
      document.getElementById('f_password').value = '';
      document.getElementById('f_is_active').checked = true;
      renderAppsCheckboxes([]);
      openModal();
    });

    async function openEditModal(userId) {
      try {
        const u = await api('/users/' + userId + '/');
        document.getElementById('editingId').value = u.id;
        modalTitle.textContent = 'Editar usuário';
        submitBtn.textContent = 'Salvar alterações';
        passwordLbl.textContent = 'Senha (opcional)';
        document.getElementById('f_password').required = false;
        document.getElementById('f_email').value = u.email;
        document.getElementById('f_first_name').value = u.first_name;
        document.getElementById('f_last_name').value = u.last_name;
        document.getElementById('f_role').value = u.role;
        document.getElementById('f_setor').value = u.setor || '';
        document.getElementById('f_password').value = '';
        document.getElementById('f_is_active').checked = u.is_active;
        renderAppsCheckboxes(u.aplicacoes ? u.aplicacoes.map(a => a.id) : []);
        openModal();
      } catch (err) { alert(err.message); }
    }

    function renderAppsCheckboxes(selectedIds) {
      if (!allApps.length) { appsSection.classList.add('hidden'); return; }
      appsSection.classList.remove('hidden');
      appsGridEl.innerHTML = allApps.map(app => `
        <label class="flex items-center gap-3 rounded-2xl border border-slate-100 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700 hover:bg-slate-100 transition cursor-pointer">
          <input type="checkbox" class="app-chk accent-sid-600 w-4 h-4 rounded" data-appid="${app.id}" ${selectedIds.includes(app.id) ? 'checked' : ''} />
          ${app.nome}
        </label>
      `).join('');
    }

    document.getElementById('modalCloseBtn').addEventListener('click', closeModal);
    document.getElementById('modalCancelBtn').addEventListener('click', closeModal);

    // ─── Form submit ─────────────────────────────────────────────
    document.getElementById('userForm').addEventListener('submit', async e => {
      e.preventDefault();
      formErrorEl.classList.add('hidden');
      submitBtn.disabled = true;

      const editingId = document.getElementById('editingId').value;
      const pw = document.getElementById('f_password').value;
      const selectedApps = Array.from(document.querySelectorAll('.app-chk:checked')).map(c => Number(c.dataset.appid));

      const payload = {
        email: document.getElementById('f_email').value.trim().toLowerCase(),
        first_name: document.getElementById('f_first_name').value,
        last_name: document.getElementById('f_last_name').value,
        role: document.getElementById('f_role').value,
        setor: document.getElementById('f_setor').value || null,
        is_active: document.getElementById('f_is_active').checked,
        aplicacoes: selectedApps,
      };

      if (editingId) {
        if (pw) payload.password = pw;
      } else {
        payload.password = pw;
      }

      try {
        if (editingId) {
          await api('/users/' + editingId + '/', { method: 'PATCH', body: JSON.stringify(payload) });
        } else {
          await api('/users/', { method: 'POST', body: JSON.stringify(payload) });
        }
        closeModal();
        loadUsers();
      } catch (err) {
        formErrorEl.textContent = err.message; formErrorEl.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
      }
    });

    // ─── Delete ──────────────────────────────────────────────────
    async function handleDelete(id, email) {
      if (!confirm('Excluir o usuário ' + email + '?')) return;
      try {
        await api('/users/' + id + '/', { method: 'DELETE' });
        loadUsers();
      } catch (err) { alert(err.message); }
    }

    // ─── Logout ──────────────────────────────────────────────────
    function handleLogout() { clearSession(); window.location.href = '/login'; }
    document.getElementById('logoutBtn').addEventListener('click', handleLogout);
    document.getElementById('logoutBtnMobile')?.addEventListener('click', handleLogout);

    // ─── Init ────────────────────────────────────────────────────
    (async function init() {
      try { allApps = await api('/apps/'); } catch { allApps = []; }
      loadUsers();
    })();
  </script>
</body>
</html>

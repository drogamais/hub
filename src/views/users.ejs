<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hub Drogamais – Usuários</title>
  <link rel="stylesheet" href="/public/css/style.css">
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top,_#f8fafc,_#e2e8f0_100%)] font-sans">
  <div class="flex h-screen overflow-hidden">

    <aside class="hidden w-64 flex-shrink-0 flex-col bg-white shadow-panel lg:flex">
      <div class="flex h-16 items-center gap-3 px-6 border-b border-slate-100">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-sid-600 text-sm font-bold text-white">H</div>
        <span class="text-lg font-bold text-ink">Hub Drogamais</span>
      </div>
      <nav class="flex-1 space-y-1 px-3 py-4">
        <a href="/app/hub" class="flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition">
          <span>📊</span> Aplicativos
        </a>
        <a href="/app/users" class="flex items-center gap-3 rounded-xl bg-sid-50 px-4 py-2.5 text-sm font-semibold text-sid-700">
          <span>👥</span> Usuários
        </a>
      </nav>
      <div class="border-t border-slate-100 px-4 py-4">
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-100 text-sm font-bold text-slate-600">
            <%= (user.first_name[0] || '') + (user.last_name[0] || '') %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="truncate text-sm font-semibold text-ink"><%= user.first_name %> <%= user.last_name %></p>
            <p class="truncate text-xs text-slate-400"><%= user.email %></p>
          </div>
        </div>
        <button onclick="handleLogout()" class="mt-3 w-full rounded-xl border border-slate-200 px-3 py-2 text-xs font-medium text-slate-500 transition hover:bg-red-50 hover:text-red-600 hover:border-red-200">Sair</button>
      </div>
    </aside>

    <main class="flex-1 overflow-y-auto">
      <div class="mx-auto max-w-7xl p-8 space-y-6">

        <section class="rounded-3xl bg-white p-6 shadow-panel">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Administração</p>
              <h2 class="text-3xl font-bold text-ink">Usuários</h2>
              <p class="mt-2 text-sm text-slate-500">Cadastro e manutenção de acessos restritos ao perfil admin.</p>
            </div>
            <button onclick="openModal()" class="rounded-2xl bg-sid-600 px-4 py-3 text-sm font-semibold text-white hover:bg-sid-700">Novo usuário</button>
          </div>
        </section>

        <section class="rounded-3xl bg-white p-6 shadow-panel">
          <div class="relative">
            <input type="text" name="search" 
                   class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none transition focus:border-sid-500 focus:bg-white" 
                   placeholder="Buscar por nome ou e-mail..."
                   hx-get="/api/users" 
                   hx-trigger="keyup changed delay:500ms" 
                   hx-target="#usersTableBody"
                   hx-indicator="#spinner">
            <div id="spinner" class="htmx-indicator absolute right-4 top-3">
               <div class="animate-spin h-5 w-5 border-2 border-sid-500 border-t-transparent rounded-full"></div>
            </div>
          </div>
        </section>

        <section class="overflow-hidden rounded-3xl bg-white shadow-panel">
          <div class="overflow-x-auto">
            <table class="min-w-full border-collapse">
              <thead class="bg-slate-50 text-left text-xs uppercase tracking-[0.18em] text-slate-500">
                <tr>
                  <th class="px-5 py-4">Nome</th>
                  <th class="px-5 py-4">E-mail</th>
                  <th class="px-5 py-4">Perfil</th>
                  <th class="px-5 py-4">Setor</th>
                  <th class="px-5 py-4">Ações</th>
                </tr>
              </thead>
              <tbody id="usersTableBody">
                <%- include('partials/user-table-rows', { users: users }) %>
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </main>
  </div>

  <div id="formModal" class="fixed inset-0 z-50 hidden items-start justify-center bg-slate-950/30 px-4 py-8">
     </div>

  <script src="/public/js/auth.js"></script>
  <script src="/public/js/user-ui.js"></script>
</body>
</html>